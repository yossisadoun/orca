{
  "name": "orca-plan",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"ORCA_PLAN_DEV_PORT=5180 vite\" \"wait-on tcp:127.0.0.1:5180 && ORCA_PLAN_DEV_PORT=5180 node ./node_modules/electron/cli.js ./electron/main.cjs --dev\"",
    "build": "tsc -b && vite build",
    "start:electron": "node ./node_modules/electron/cli.js ./electron/main.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^4.0.3",
    "lucide-react": "^1.14.0",
    "node-pty": "^1.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^8.0.5"
  }
}
